# ─── Dependencies ────────────────────────────────────────────────
node_modules/
frontend/node_modules/
backend/node_modules/

# ─── Build Output ─────────────────────────────────────────────────
frontend/dist/
frontend/.vite/

# ─── Environment Variables ─────────────────────────────────────────
# NEVER commit .env files
.env
backend/.env
frontend/.env
*.env.local
*.env.development.local
*.env.test.local
*.env.production.local

# ─── Firebase Credentials ─────────────────────────────────────────
# NEVER commit service account keys
backend/serviceAccountKey.json
backend/*-firebase-adminsdk-*.json
serviceAccountKey.json

# ─── Local Database ───────────────────────────────────────────────
# Production uses Supabase — SQLite is for local dev only
backend/database.sqlite
*.sqlite
*.sqlite3

# ─── Logs ─────────────────────────────────────────────────────────
*.log
log.txt
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ─── OS Files ─────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Desktop.ini

# ─── Editor & IDE ─────────────────────────────────────────────────
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

